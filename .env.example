# ─── Production (Vercel / hosting) ───────────────────────────────────────────
# Set in hosting dashboard; redeploy after changes (baked in at build time).

# Backend API (required)
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com/api/v1

# Public app URL (recommended — align with backend APP_FRONTEND_URL)
NEXT_PUBLIC_APP_FRONTEND_URL=https://app.yourdomain.com

# Optional: default tenant slug on login (use kofeko-test after npm run seed:test)
# NEXT_PUBLIC_DEFAULT_TENANT_SLUG=kofeko-test

# Optional: candidate Supabase auth (only if using Supabase login flows)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ─── Local development ───────────────────────────────────────────────────────
# NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api/v1
# NEXT_PUBLIC_APP_FRONTEND_URL=http://localhost:3000
